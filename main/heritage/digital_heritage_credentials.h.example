#ifndef DIGITAL_HERITAGE_CREDENTIALS_H
#define DIGITAL_HERITAGE_CREDENTIALS_H

#define DH_WIFI_NETWORK_ENTRY(SSID, PASS, MQTT_URI) \
    { (SSID), (PASS), (MQTT_URI) }

/* SSID、密码、该网络下 PC 的 MQTT 地址（TCP 1883） */
#define DH_WIFI_NETWORK_TABLE \
    DH_WIFI_NETWORK_ENTRY("your-wifi-1", "password-1", "mqtt://192.168.1.100:1883"), \
    DH_WIFI_NETWORK_ENTRY("your-wifi-2", "password-2", "mqtt://192.168.5.1:1883")

#define DH_MQTT_BROKER_URI "mqtt://192.168.5.1:1883"

#endif /* DIGITAL_HERITAGE_CREDENTIALS_H */
